# ============================================================
# DEV environment — points to your SEPARATE Supabase dev project
# 1. Create a new Supabase project at supabase.com (name it "night-vibe-dev")
# 2. Copy this file: cp .env.development.local.example .env.development.local
# 3. Fill in the values from that new project's Settings > API
# 4. Run the migration: paste supabase/migrations/001_saved_spots.sql in its SQL editor
#
# `npm run dev` will load this file INSTEAD of .env.local
# ============================================================

# ---- Supabase DEV project -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-DEV-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_DEV_ANON_KEY

SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_DEV_SERVICE_ROLE_KEY

# ---- Shared Agent Board project -----------------------------
# The admin /agent-board route reads the shared Agent Board database.
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_URL=https://gfsbqewkrcyclbktfyfk.supabase.co
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_ANON_KEY=sb_publishable_YOUR_AGENT_BOARD_ANON_KEY

# ---- OpenAI (shared — same key is fine for dev) -------------
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# ---- Google Maps (shared — same keys work across envs) ------
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_KEY

# ---- Dev-only flags -----------------------------------------
NEXT_PUBLIC_ENV=development
