# ============================================================
# PRODUCTION environment — add these as Environment Variables
# in the Vercel dashboard (Settings > Environment Variables)
# Set scope to "Production" for each one.
# NEVER commit the actual values to git.
# ============================================================

# ---- Supabase PRODUCTION project ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROD-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PROD_ANON_KEY

SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_PROD_SERVICE_ROLE_KEY

# ---- OpenAI -------------------------------------------------
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# ---- Google Maps --------------------------------------------
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_KEY

# ---- Production flags ---------------------------------------
NEXT_PUBLIC_ENV=production
