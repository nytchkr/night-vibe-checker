# ============================================================
# PRODUCTION environment — add these as Environment Variables
# in the Vercel dashboard (Settings > Environment Variables)
# Set scope to "Production" for each one.
# NEVER commit the actual values to git.
# ============================================================

# ---- Supabase PRODUCTION project ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROD-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PROD_ANON_KEY

SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_PROD_SERVICE_ROLE_KEY

# ---- Shared Agent Board project -----------------------------
# Optional when production app Supabase and Agent Board Supabase are the same project.
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_URL=https://gfsbqewkrcyclbktfyfk.supabase.co
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_ANON_KEY=sb_publishable_YOUR_AGENT_BOARD_ANON_KEY

# ---- OpenAI -------------------------------------------------
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# ---- Google Maps --------------------------------------------
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_BROWSER_KEY

# ---- Google OAuth / Auth.js ---------------------------------
# SERVER-SIDE ONLY. Authorized production redirect URI:
# https://nytchkr.com/api/auth/callback/google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
AUTH_SECRET=YOUR_AUTH_SECRET
NEXTAUTH_SECRET=YOUR_AUTH_SECRET
AUTH_URL=https://nytchkr.com
NEXTAUTH_URL=https://nytchkr.com

# ---- Web Push ------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# ---- Sentry --------------------------------------------------
# Replace this placeholder with the real Sentry DSN for production monitoring.
NEXT_PUBLIC_SENTRY_DSN=https://placeholder@sentry.io/placeholder

# ---- Production flags ---------------------------------------
NEXT_PUBLIC_ENV=production

# ---- Admin auth gate for /agent-board -----------------
# SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix
ADMIN_PASSWORD=your-admin-password-here
