# ============================================================
# Night Vibe Checker — Local development environment
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.
# ============================================================

# ---- Supabase app project -----------------------------------
# Required by server routes and browser auth clients.
# Found in Supabase Dashboard > Project Settings > API.
# Public URL for the Supabase project used by local Night Vibe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon/publishable key. Safe for browser use; still required locally.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only service role key. Required by /api/check-ins, /api/venues,
# /api/admin/*, background jobs, and signal recomputation. Never expose this
# with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Shared Agent Board project -----------------------------
# Used only by /agent-board and internal ticket coordination surfaces.
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_URL=https://gfsbqewkrcyclbktfyfk.supabase.co
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_ANON_KEY=your-agent-board-anon-key

# ---- OpenAI --------------------------------------------------
# Server-only key for AI-powered vibe reports and scoring routes.
OPENAI_API_KEY=sk-proj-your-openai-api-key

# ---- Google Maps / Places -----------------------------------
# Server-only Places key for discovery/search jobs and venue enrichment.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Browser Maps JavaScript key for map rendering.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# ---- Web Push ------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ---- App mode -----------------------------------------------
# Shows the development banner and enables local-only test affordances.
NEXT_PUBLIC_ENV=development

# ---- Internal admin surfaces --------------------------------
# Password gate for /agent-board.
ADMIN_PASSWORD=your-admin-password

# Comma-separated Supabase user email allowlist for /admin moderation.
ADMIN_EMAILS=alice@example.com,bob@example.com

# ---- Optional local tuning ----------------------------------
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000
