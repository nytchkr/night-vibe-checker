# ============================================================
# Night Vibe Checker — Local development environment
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.
# ============================================================

# ---- Supabase app project -----------------------------------
# Required by server routes and browser auth clients.
# Found in Supabase Dashboard > Project Settings > API.
# Public URL for the Supabase project used by local Night Vibe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon/publishable key. Safe for browser use; still required locally.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only service role key. Required by /api/check-ins, /api/venues,
# /api/admin/*, background jobs, and signal recomputation. Never expose this
# with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Shared Agent Board project -----------------------------
# Used only by /agent-board and internal ticket coordination surfaces.
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_URL=https://gfsbqewkrcyclbktfyfk.supabase.co
NEXT_PUBLIC_AGENT_BOARD_SUPABASE_ANON_KEY=your-agent-board-anon-key

# ---- OpenAI --------------------------------------------------
# Server-only key for AI-powered vibe reports and scoring routes.
OPENAI_API_KEY=sk-proj-your-openai-api-key

# ---- Google Maps / Places -----------------------------------
# Server-only Places key for discovery/search jobs and venue enrichment.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Browser Maps JavaScript key for map rendering.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# ---- Google OAuth / Auth.js ---------------------------------
# Server-only OAuth client for NextAuth/Auth.js. Authorized redirect URI:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
AUTH_SECRET=your-auth-secret
NEXTAUTH_SECRET=your-auth-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ---- Web Push ------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:alerts@example.com

# ---- Cron ----------------------------------------------------
CRON_SECRET=your-cron-secret

# ---- Upstash Redis / QStash ---------------------------------
# Server-only production infrastructure values. In Azure Static Web Apps,
# configure these under Portal > Static Web Apps > Configuration >
# Application settings. Never commit real values.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# ---- Stripe --------------------------------------------------
# Server-only billing keys. Prefer restricted keys with minimum permissions.
STRIPE_SECRET_KEY=rk_test_your-restricted-stripe-key
STRIPE_PRICE_PRO_MONTHLY=price_your_monthly_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Sentry --------------------------------------------------
# Replace this placeholder with the real Sentry DSN for production monitoring.
NEXT_PUBLIC_SENTRY_DSN=https://placeholder@sentry.io/placeholder

# ---- App mode -----------------------------------------------
# Shows the development banner and enables local-only test affordances.
NEXT_PUBLIC_ENV=development

# ---- Internal admin surfaces --------------------------------
# Password gate for /agent-board.
ADMIN_PASSWORD=your-admin-password

# Comma-separated Supabase user email allowlist for /admin moderation.
ADMIN_EMAILS=alice@example.com,bob@example.com

# ---- Optional local tuning ----------------------------------
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000
